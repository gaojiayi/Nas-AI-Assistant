{
  "mcpServers": {
    "amap-maps": {
      "command": "npx",
      "args": [
        "-y",
        "@amap/amap-maps-mcp-server"
      ],
      "env": {
        "AMAP_MAPS_API_KEY": ""
      }
    },
     "smart-image-scraper": {
      "command": "npx",
      "args": [
        "-y",
        "smart-image-scraper-mcp"
      ],
      "env": {
        "IMAGE_OUTPUT_DIR": "./images" 
      }
    }
  }
}